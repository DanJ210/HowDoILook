# Required environment variables — copy to .env and fill in values
# Never commit the actual .env file

# ── Azure Storage Queue ──────────────────────────────────────────
QUEUE_CONNECTION_STRING=
QUEUE_NAME=style-jobs

# ── Azure Blob Storage ───────────────────────────────────────────
BLOB_CONNECTION_STRING=
BLOB_CONTAINER_NAME=style-assets

# ── JWT (Backend API) ────────────────────────────────────────────
JWT_KEY=
JWT_ISSUER=ai-style-app
JWT_AUDIENCE=ai-style-app-client
